  "behavior": {
    "cookieConsentSelectors": [],
    "popupDismissSelectors": [],
    "aiExpandSelectors": [
      "[data-testid=\"duckassist-stream-more-pill\"]",
      ".module__toggle--more"
    ],
    "stickyHeaderSelectors": [
      ".header-wrap"
    ]
  },
  "captcha": {
    "urlIndicators": [],
    "textIndicators": [],
    "selectors": []
  },
  "selectors": {
    "pagination": {
      "nextButton": "#more-results, button.result--more__btn, a.result--more__btn",
      "fallbackActiveSibling": ""
    },
    "organic": {
      "mainCol": "#links, .react-results--main",
      "container": "article[data-testid=\"result\"], article[data-nrn=\"result\"], div.result",
      "excludeContainers": [
        ".module--carousel",
        ".has-image"
      ],
      "title": "a[data-testid=\"result-title-a\"], h2 a",
      "url": "a[data-testid=\"result-title-a\"], h2 a",
      "snippet": {
        "selector": "[data-result=\"snippet\"], [data-testid=\"result-snippet\"], .result__snippet",
        "minLength": 0
      }
    },
    "ads": {
      "container": "article[data-testid=\"ad\"], .result--ad",
      "title": "a[data-testid=\"result-title-a\"], h2 a",
      "url": "a[data-testid=\"result-title-a\"], h2 a",
      "snippet": {
        "selector": "[data-result=\"snippet\"], [data-testid=\"result-snippet\"], .result__snippet",
        "maxLength": 300
      }
    },
    "ai_overview": {
      "container": "[data-react-module-id=\"wikinlp\"]",
      "text": {
        "selector": "[data-testid=\"duckassist-answer-content\"], .duckassist-answer",
        "regexClean": ""
      },
      "sources": [
        {
          "type": "standard",
          "container": "[data-react-module-id=\"wikinlp\"] li, [data-testid=\"duckassist-source\"]",
          "title": "span",
          "url": "a"
        }
      ]
    }
  }
