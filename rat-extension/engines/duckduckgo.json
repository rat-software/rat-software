  "engine": {
    "id": "duckduckgo",
    "name": "DuckDuckGo",
    "author": "RAT System",
    "version": "2.3",
    "description": "Scraper for DuckDuckGo"
  },
  "request": {
    "baseUrl": "https://duckduckgo.com/?ia=web&assist=true",
    "params": {
      "query": "q",
      "country": "kl",
      "language": "kad"
    },
    "features": {
      "requiresUuleEncoding": false,
      "urlDecodingMethod": "none"
    },
    "supportedCountries": [
