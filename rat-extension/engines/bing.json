{
  "manifest_version": 1,
  "engine": {
    "id": "bing",
    "name": "Bing",
    "author": "RAT System",
    "version": "1.0",
    "description": "Standard Scraper for Bing Search (includes Copilot Chat, Ads, and Organic)"
  },
  "request": {
    "baseUrl": "https://www.bing.com/search",
    "params": {
      "query": "q",
      "country": "cc",
      "language": "setLang"
    },
    "features": {
      "requiresUuleEncoding": false,
      "urlDecodingMethod": "bing_base64"
    },
    "supportedCountries": [
