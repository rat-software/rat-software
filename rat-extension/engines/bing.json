      },
      {
        "code": "ru",
        "name": "Russia"
      },
      {
        "code": "sg",
        "name": "Singapore"
      },
      {
        "code": "es",
        "name": "Spain"
      },
      {
        "code": "se",
        "name": "Sweden"
      },
      {
        "code": "ch",
        "name": "Switzerland"
      },
      {
        "code": "gb",
        "name": "United Kingdom"
      },
      {
        "code": "us",
        "name": "USA"
      }
    ],
    "supportedLanguages": [
      {
        "code": "en",
