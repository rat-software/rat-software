  "behavior": {
    "cookieConsentSelectors": [
      "#bnp_btn_accept",
      ".bnp_btn_accept"
    ],
    "popupDismissSelectors": [],
    "aiExpandSelectors": [
      ".gs_readMoreFullBtn",
      ".cit_exp_btn"
    ],
    "stickyHeaderSelectors": [
      "#b_header",
      ".b_searchboxForm",
      "[style*=\"position: fixed\"]",
      "[style*=\"position: sticky\"]"
    ]
  },
  "captcha": {
    "urlIndicators": [],
    "textIndicators": [],
    "selectors": [
      ".g-recaptcha",
      "#recaptcha",
      "iframe[src*=\"recaptcha\"]"
    ]
  },
  "selectors": {
    "pagination": {
      "nextButton": "a.sb_pagN, a[title=\"Nächste Seite\"], a[title=\"Page suivante\"], a[title=\"Pagina successiva\"], a[title=\"Next page\"]",
      "fallbackActiveSibling": ".sb_pagS"
    },
    "organic": {
      "mainCol": "#b_results",
      "container": "li.b_algo, li.b_algo_group",
      "excludeContainers": [
        ".algoSlug_icon"
      ],
      "title": "h2 a",
      "url": "h2 a",
      "snippet": {
        "selector": ".b_caption p, .b_algoSlug, .b_algo_snippet, .b_lineclamp",
        "minLength": 0
      }
    },
    "ads": {
      "container": "li.b_ad",
      "title": ".tptt, h2",
      "url": "a",
      "snippet": {
        "selector": ".b_ad_description, .b_lineclamp",
        "maxLength": 200
      }
    },
    "ai_overview": {
      "container": "div.gs_h.gs_caphead",
      "text": {
        "selector": ".gs_text",
        "regexClean": "^(Bilder\\s*|Videos\\s*)+"
      },
      "sources": [
        {
          "type": "attribute_based",
          "container": ".gs_cit",
          "titleAttribute": "data-title",
          "urlAttribute": "data-url"
        },
        {
          "type": "standard",
          "container": ".hov-item",
          "title": ".hov-item-ttl",
          "url": "a"
        }
      ]
    }
  }
}